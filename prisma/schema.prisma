generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BusinessUnit {
  bu_id          Int      @id @default(autoincrement())
  bu_code        String   @unique @db.VarChar(20)
  bu_name        String   @db.VarChar(100)
  bu_description String?  @db.Text
  contact_person String?  @db.VarChar(100)
  phone          String?  @db.VarChar(50)
  line_id        String?  @db.VarChar(50)
  website        String?  @db.VarChar(255)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  users          User[]
  systems        SystemGroup[]
  tickets        Ticket[]
  job_counters   JobCounter[]
  locations      Location[]
}

model SystemGroup {
  system_id     Int      @id @default(autoincrement())
  system_code   String   @unique @db.VarChar(20)
  system_name   String   @db.VarChar(100)
  system_type   String   @db.VarChar(20)
  group_name    String?  @db.VarChar(50)
  vendor        String?  @db.VarChar(100)
  version       String?  @db.VarChar(50)
  owner_bu_id   Int?
  owner_user_id Int?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  owner_bu      BusinessUnit? @relation(fields: [owner_bu_id], references: [bu_id])
  owner_user    User?         @relation("SystemOwner", fields: [owner_user_id], references: [user_id])
  tickets       Ticket[]
}

model User {
  user_id      Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(255)
  full_name    String   @db.VarChar(100)
  phone        String?  @db.VarChar(20)
  role         String   @db.VarChar(20)
  bu_id        Int?
  location_id  Int?
  avatar_url   String?  @db.Text
  password     String?  @db.VarChar(255)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  bu               BusinessUnit? @relation(fields: [bu_id], references: [bu_id])
  location         Location?     @relation(fields: [location_id], references: [location_id])

  messages         TicketMessage[]

  reported_tickets Ticket[]      @relation("Reporter")
  tier1_tickets    Ticket[]      @relation("Tier1Assigned")
  tier2_tickets    Ticket[]      @relation("Tier2Assigned")
  tier3_tickets    Ticket[]      @relation("Tier3Assigned")
  owner_tickets    Ticket[]      @relation("OwnerAssigned")
  owned_systems    SystemGroup[] @relation("SystemOwner")
}

model Location {
  location_id   Int      @id @default(autoincrement())
  location_code String   @unique @db.VarChar(20)
  location_name String   @db.VarChar(100)
  location_type String   @db.VarChar(30)
  floor         String?  @db.VarChar(20)
  address       String?  @db.Text
  bu_id         Int?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  bu            BusinessUnit? @relation(fields: [bu_id], references: [bu_id])
  users         User[]
  tickets       Ticket[]
}

model Ticket {
  ticket_id           Int      @id @default(autoincrement())
  ticket_no           String   @unique @db.VarChar(30)
  subject             String   @db.VarChar(255)
  problem_type        String   @db.VarChar(20)
  system_id           Int
  location_id         Int?
  location_text       String?  @db.VarChar(200)
  reporter_id         Int?
  reporter_name       String?  @db.VarChar(100)
  reporter_email      String?  @db.VarChar(255)
  reporter_phone      String?  @db.VarChar(20)
  reporter_line_id    String?  @db.VarChar(50)
  bu_id               Int
  tier1_id            Int?
  tier2_id            Int?
  tier3_id            Int?
  owner_id            Int?
  status              String   @default("NEW") @db.VarChar(30)
  priority            String   @db.VarChar(20)
  description         String   @db.Text
  symptom             String   @db.Text

  initial_assessment  String?  @db.Text
  preliminary_cause   String?  @db.Text
  tier1_action        String?  @db.Text
  is_escalated        Boolean  @default(false)
  escalate_reason     String?  @db.Text

  root_cause          String?  @db.Text
  root_cause_category String?  @db.VarChar(50)
  resolution          String?  @db.Text
  resolution_detail   String?  @db.Text
  preventive_action   String?  @db.Text

  user_satisfaction   Int?
  user_comment        String?  @db.Text

  created_at          DateTime @default(now())
  tier1_accepted_at   DateTime?
  tier1_assessed_at   DateTime?
  escalated_at        DateTime?
  tier2_accepted_at   DateTime?
  tier3_assigned_at   DateTime?
  tier3_accepted_at   DateTime?
  estimated_resolve_time DateTime?
  assumption          String?  @db.Text
  repair_started_at   DateTime?
  resolved_at         DateTime?
  user_confirmed_at   DateTime?
  closed_at           DateTime?
  reopened_at         DateTime?
  updated_at          DateTime @updatedAt

  system              SystemGroup  @relation(fields: [system_id], references: [system_id])
  location            Location?    @relation(fields: [location_id], references: [location_id])
  reporter            User?        @relation("Reporter", fields: [reporter_id], references: [user_id])
  tier1               User?        @relation("Tier1Assigned", fields: [tier1_id], references: [user_id])
  tier2               User?        @relation("Tier2Assigned", fields: [tier2_id], references: [user_id])
  tier3               User?        @relation("Tier3Assigned", fields: [tier3_id], references: [user_id])
  owner               User?        @relation("OwnerAssigned", fields: [owner_id], references: [user_id])
  bu                  BusinessUnit @relation(fields: [bu_id], references: [bu_id])
  hardware_id         Int?
  hardware            Hardware?    @relation(fields: [hardware_id], references: [hardware_id])
  attachments         Attachment[]
  audit_logs          AuditLog[]
  messages            TicketMessage[]
}

model Attachment {
  attachment_id Int      @id @default(autoincrement())
  ticket_id     Int
  file_name     String   @db.VarChar(255)
  file_url      String   @db.Text
  file_type     String   @db.VarChar(100)
  file_size     Int
  uploaded_by   Int
  created_at    DateTime @default(now())

  ticket        Ticket   @relation(fields: [ticket_id], references: [ticket_id])
}

model AuditLog {
  log_id        Int      @id @default(autoincrement())
  ticket_id     Int?
  user_id       Int
  action        String   @db.VarChar(50)
  detail        String?  @db.Text
  old_value     String?  @db.Text
  new_value     String?  @db.Text
  created_at    DateTime @default(now())

  ticket        Ticket?  @relation(fields: [ticket_id], references: [ticket_id])
}

model JobCounter {
  counter_id    Int      @id @default(autoincrement())
  bu_code       String   @db.VarChar(20)
  bu_id         Int
  date_key      String   @db.VarChar(10)
  last_number   Int      @default(0)

  bu            BusinessUnit @relation(fields: [bu_id], references: [bu_id])

  @@unique([bu_code, date_key])
}

model Hardware {
  hardware_id    Int      @id @default(autoincrement())
  hardware_code  String   @unique @db.VarChar(50)
  hardware_name  String   @db.VarChar(100)
  brand          String?  @db.VarChar(50)
  model          String?  @db.VarChar(50)
  description    String?  @db.Text
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  symptoms       HardwareSymptom[]
  tickets        Ticket[]
}

model HardwareSymptom {
  symptom_id     Int      @id @default(autoincrement())
  hardware_id    Int
  symptom_code   String   @db.VarChar(50)
  symptom_name   String   @db.VarChar(100)
  description    String?  @db.Text
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  hardware       Hardware @relation(fields: [hardware_id], references: [hardware_id], onDelete: Cascade)

  @@unique([hardware_id, symptom_code])
}

model TicketMessage {
  message_id    Int      @id @default(autoincrement())
  ticket_id     Int
  sender_type   String   @db.VarChar(20) // 'REPORTER', 'AGENT', 'BOT'
  sender_id     Int?     
  sender_name   String?  @db.VarChar(100) 
  message_text  String   @db.Text
  source        String   @db.VarChar(20) // 'WEB', 'LINE'
  created_at    DateTime @default(now())

  ticket        Ticket   @relation(fields: [ticket_id], references: [ticket_id], onDelete: Cascade)
  sender        User?    @relation(fields: [sender_id], references: [user_id])
}

model SystemConfig {
  config_id    Int      @id @default(autoincrement())
  config_key   String   @unique @db.VarChar(100)
  config_value String?  @db.Text
  description  String?  @db.Text
  is_secret    Boolean  @default(false)
  updated_at   DateTime @updatedAt
  updated_by   Int?
}
